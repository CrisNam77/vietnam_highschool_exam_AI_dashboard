APP_NAME=vietnam-highschool-exam-ai-dashboard
APP_ENV=local

DATA_PATH=data/processed/final_data.csv
LOG_PATH=data/logs/interaction_history.json
SQLITE_DB_PATH=database/logs.db

FASTAPI_BASE_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8001
BACKEND_URL=http://127.0.0.1:8001

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# --- Các biến cấu hình Deploy Hugging Face Spaces ---
# HF_DATASET_REPO: Tên repo dataset HF chứa final_data.parquet
# HF_DATASET_REPO=your-org/vietnam-highschool-exam-dataset
# ALLOWED_ORIGINS: Các domain được phép gọi API (frontend)
# ALLOWED_ORIGINS=https://vietnam-highschool-exam-ai-dashboar.vercel.app,http://localhost:3000
# EXECUTION_TIMEOUT: Số giây tối đa chạy code AI
# EXECUTION_TIMEOUT=30
# OPENROUTER_MODELS: Danh sách các model fallback (cách nhau bởi dấu phẩy) nếu bị 429/404
# OPENROUTER_MODELS=openai/gpt-4.1-mini,google/gemini-2.5-flash
# LOG_PATH=/tmp/logs/interaction_history.json
